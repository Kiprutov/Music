+module.exports = (sequelize, DataTypes) => {
+    const Song = sequelize.define('Song', {
+        title: {
+            type: DataTypes.STRING,
+            allowNull: false
+        },
+        artist: {
+            type: DataTypes.STRING,
+            allowNull: false
+        },
+        album: {
+            type: DataTypes.STRING,
+            defaultValue: 'Unknown Album'
+        },
+        url: {
+            type: DataTypes.STRING,
+            allowNull: false,
+            comment: 'URL or path to the audio file'
+        },
+        duration: {
